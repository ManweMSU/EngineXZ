		functio @fenestrae.fenestra crea_fenestram(~crea_fenestram_desc desc, fenestrae.classis_machinationis cls) iacit {
			var ~ sysfen = fenestrae.systema_fenestrarum.currens();
			_pons_iu.communalis().planus0(19, (nintadl)(@sysfen), 0, 0, 0, 0);
			responde (@fenestrae.fenestra)(_pons_iu.communalis().planus0(1, (nintadl)(@desc), 0, 0, 0, nint(cls)));
		}
