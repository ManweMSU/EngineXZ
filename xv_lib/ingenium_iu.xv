importa fenestrae;
importa graphicum;

auxilium attributum (meta.attributum_nomen_moduli) = "Liber Intercommunicationis cum Usore";
auxilium attributum (meta.attributum_creator_moduli) = "Engine Software";
auxilium attributum (meta.attributum_iura_exempli) = "© Engine Software. 2026";
auxilium attributum (meta.attributum_versio) = "1.0.0.1";

auxilium versio 0;

[[systema] librosa]

spatium ingenium {
	spatium iu {
		protocollum _pons_iu {
			[[inline]] classis functio ~_pons_iu communalis() { responde (@_pons_iu)(protocollum("ingenium.pons.iu"))^; }

			functio nintadl planus0(nint32 sel, nintadl a0, nintadl a1, nintadl a2, nintadl a3, nintadl a4) iacit virtualis pura;
			functio nintadl planus1(@objectum obj, nint32 sel, nintadl a0, nintadl a1, nintadl a2, nintadl a3, nintadl a4) iacit virtualis pura;
			functio nintadl planus2(@objectum obj, nint32 sel, nintadl a0, nintadl a1, nintadl a2, nintadl a3, nintadl a4) iacit virtualis pura;
		}
		[[initium]] functio nihil __ini() iacit {
			_pons_iu.communalis().planus0(17, (nintadl)(int), (nintadl)(dfrac), (nintadl)(imago.color), (nintadl)(linea), 0);
			_pons_iu.communalis().planus0(18, (nintadl)(!graphicum.pictura), (nintadl)(!graphicum.typographica), 0, 0, (nintadl)(_pons_iu));
		}

		structura positus {
			dfrac relativus;
			dfrac scalabilis;
			int absolutus;

			structor (int pabs) { funda absolutus(pabs); funda relativus(0.0); funda scalabilis(0.0); }
			structor (int pabs, dfrac pscal) { funda absolutus(pabs); funda scalabilis(pscal); funda relativus(0.0); }
			structor (int pabs, dfrac pscal, dfrac prel) { funda absolutus(pabs); funda scalabilis(pscal); funda relativus(prel); }

			classis functio positus sinister() { responde positus(0, 0.0, 0.0); }
			classis functio positus dextrus() { responde positus(0, 0.0, 1.0); }
			classis functio positus invalidus() { responde positus(0, 0.0, math.nn_d()); }
		}
		structura quadrum {
			positus sinister;
			positus superus;
			positus dextrus;
			positus inferus;

			structor (~positus sin, ~positus sup, ~positus dex, ~positus inf) { funda sinister(sin); funda superus(sup); funda dextrus(dex); funda inferus(inf); }

			classis functio quadrum parens() { responde quadrum(0, 0, positus.dextrus(), positus.dextrus()); }
			classis functio quadrum invalidum() { responde quadrum(positus.invalidus(), positus.invalidus(), positus.invalidus(), positus.invalidus()); }
		}
		genus visualis hereditat objectum {
			functio nihil redde(@graphicum.contextus_machinae ctx, ~fenestrae.quadrum in) virtualis pura;
			functio nihil depura() virtualis pura;
			functio !visualis cloniza() iacit virtualis pura;
		}
		protocollum argumentor {
			functio nihil da_valorem_argumenti(~linea nomen, @nihil gens, @nihil adloq) iacit virtualis pura;
		}
		genus visualis_incompletus hereditat objectum {
			functio !visualis crea_exemplum(@argumentor arg) iacit virtualis pura;
			functio !visualis crea_exemplum() iacit { responde crea_exemplum(nullus); }
		}
		structura elementum {
			!objectum _mnbr;
		}
		structura systema_elementorum {
			!objectum _mnbr;
		}
		nomen_alternum ordo_filiorum = ordo !objectum_dynamicum;
		genus praeforma_elementi hereditat objectum_dynamicum {
			structor () {}
			functio elementum crea_exemplum(~quadrum quadrum, ~ordo !objectum_dynamicum filii) iacit virtualis pura;
		}
		protocollum fabricator {
			functio !praeforma_elementi crea_praeformam_elementi(~linea nomen_generis) iacit virtualis pura;
		}
		genus praeformae hereditat objectum {
			functio ~linea onera_lineam(~linea nomen) iacit virtualis pura;
			functio imago.color onera_colorem(~linea nomen) iacit virtualis pura;
			functio !graphicum.pictura onera_picturam(~linea nomen) iacit virtualis pura;
			functio !graphicum.typographica onera_typographicam(~linea nomen) iacit virtualis pura;
			functio !visualis_incompletus onera_visualem(~linea nomen) iacit virtualis pura;
			functio !objectum_dynamicum onera_elementum(~linea nomen) iacit virtualis pura;

			classis functio !praeformae onera(@flumen fl) iacit { responde (!praeformae)((@praeformae)(_pons_iu.communalis().planus0(0, (nintadl)(fl), 0, 0, 0, 0))); }
			classis functio !praeformae onera(@flumen fl, @fabricator fab) iacit { responde (!praeformae)((@praeformae)(_pons_iu.communalis().planus0(0, (nintadl)(fl), (nintadl)(fab), 0, 0, 0))); }
		}

		enumeratio origo_eventi { imperatum = 0, accelerator = 1, minutus = 2, tactus_duplus = 3, tactus_dextrus = 4, valor_alternatus = 5, depositum = 6 }
		enumeratio ordo_elementi { move_in_primo = 0, move_in_ultimo = 1, move_proxime = 2, move_pristine = 3 }
		enumeratio animatio_elementi { nulla = 0, per_cursore = 1, cinematica = 2 }
		enumeratio modus_animationis { polita = 0, non_polita = 1 }
		enumeratio actio_animationis { nulla = 0, monstra = 1, occulta = 2, occulta_positum_retine = 3 }
		enumeratio directio_animationis { sinistra = 0, supera = 1, dextra = 2, inferna = 3 }
		enumeratio modus_ie hereditat nint32 { lege = 0, scribe = 1, adde = 2, remove = 3 }

		protocollum responsor_elementi {
			functio nihil elementum_creatum_est(~elementum el) iacit virtualis {}
			functio nihil elementum_perditum_est() iacit virtualis {}

			functio nihil elementum_redde(~elementum el, @graphicum.contextus_machinae ctx, ~fenestrae.quadrum qd) iacit virtualis {}
			functio nihil elementum_depura_data_temporale(~elementum el) iacit virtualis {}
			functio nihil elementum_repone_filios(~elementum el) iacit virtualis {}
			functio nihil elementum_motum_est(~elementum el, ~fenestrae.quadrum qd) iacit virtualis {}

			functio logicum elementum_activum_lege(~elementum el) iacit virtualis { responde sic; }
			functio logicum elementum_visibile_lege(~elementum el) iacit virtualis { responde sic; }
			functio int elementum_indentitas_lege(~elementum el) iacit virtualis { responde 0; }
			functio quadrum elementum_positus_lege(~elementum el) iacit virtualis { responde quadrum.invalidum(); }
			functio linea elementum_textum_lege(~elementum el) iacit virtualis { responde ""; }

			functio nihil elementum_activum_scribe(~elementum el, logicum valor) iacit virtualis {}
			functio nihil elementum_visibile_scribe(~elementum el, logicum valor) iacit virtualis {}
			functio nihil elementum_indentitas_scribe(~elementum el, int valor) iacit virtualis {}
			functio nihil elementum_positus_scribe(~elementum el, ~quadrum valor) iacit virtualis {}
			functio nihil elementum_textum_scribe(~elementum el, ~linea valor) iacit virtualis {}

			functio logicum tabulum_est(~elementum el) iacit virtualis { responde non; }
			functio elementum reperi_filium(~elementum el, int ind) iacit virtualis { iace errores.argumentum_falsum; }
			functio nihil procede_eventum(~elementum el, nint indent, origo_eventi org, ~elementum missor) iacit virtualis {}

			functio nihil elementum_tactus_capiebat(~elementum el, logicum cap) iacit virtualis {}
			functio logicum tactus_pressatus_est(~elementum el, tactus tact) iacit virtualis { responde non; }
			functio nihil tactus_depressatus_est(~elementum el, tactus tact) iacit virtualis {}
			functio nihil character_pressatus_est(~elementum el, char chr) iacit virtualis {}

			functio nihil elementum_mures_capiebat(~elementum el, logicum cap) iacit virtualis {}
			functio nihil mus_mota_est(~elementum el, ~fenestrae.positus pos) iacit virtualis {}
			functio nihil tactus_sinistrus_pressatus_est(~elementum el, ~fenestrae.positus pos) iacit virtualis {}
			functio nihil tactus_sinistrus_depressatus_est(~elementum el, ~fenestrae.positus pos) iacit virtualis {}
			functio nihil tactus_sinistrus_duplicatus_est(~elementum el, ~fenestrae.positus pos) iacit virtualis {}
			functio nihil tactus_dextrus_pressatus_est(~elementum el, ~fenestrae.positus pos) iacit virtualis {}
			functio nihil tactus_dextrus_depressatus_est(~elementum el, ~fenestrae.positus pos) iacit virtualis {}
			functio nihil tactus_dextrus_duplicatus_est(~elementum el, ~fenestrae.positus pos) iacit virtualis {}

			functio nihil rota_elementum_verticaliter(~elementum el, dfrac valor) iacit virtualis {}
			functio nihil rota_elementum_horizontaliter(~elementum el, dfrac valor) iacit virtualis {}

			functio nihil elementum_modum_exclusivum_perdidit(~elementum el) iacit virtualis {}
			functio nihil elementum_minutus_cancellatus_est(~elementum el) iacit virtualis {}
			functio nihil chronometrus_fierit(~elementum el) iacit virtualis {}

			functio logicum eventum_servabile_est(~elementum el, fenestrae.eventum_fenestae_globale eve) iacit virtualis { responde non; }
			functio nihil procede_eventum(~elementum el, fenestrae.eventum_fenestae_globale eve) iacit virtualis {}

			functio elementum elementum_proba_positum(~elementum el, ~fenestrae.positus pos) iacit virtualis { iace errores.argumentum_falsum; }
			functio !fenestrae.cursor elementum_imago_muris(~elementum el, ~fenestrae.positus pos) iacit virtualis { responde el.systema.lege_cursorem(fenestrae.cursor_systemae.spiculum); }
			functio animatio_elementi elementum_modus_animationis(~elementum el) iacit virtualis { responde animatio_elementi.nulla; }

			functio nihil elementum_configura(~elementum el, nint32 sel, modus_ie mod, intadl index, @nihil valor, @nihil genus_valoris) iacit virtualis {}
		}
		dura elementum {
			functio nihil redde(~fenestrae.quadrum qd) iacit { _pons_iu.communalis().planus2(_mnbr, 0x208, (nintadl)(@qd), 0, 0, 0, 0); }
			functio nihil depura_data_temporale() iacit { _pons_iu.communalis().planus2(_mnbr, 0x209, 0, 0, 0, 0, 0); }
			functio nihil repone_filios() iacit { _pons_iu.communalis().planus2(_mnbr, 0x20A, 0, 0, 0, 0, 0); }
			logicum activum { adipisce iacit {
				responde _pons_iu.communalis().planus2(_mnbr, 0x100, 0, 0, 0, 0, 0);
			} loca iacit {
				_pons_iu.communalis().planus2(_mnbr, 0x000, valor, 0, 0, 0, 0);
			} }
			logicum visibile { adipisce iacit {
				responde _pons_iu.communalis().planus2(_mnbr, 0x101, 0, 0, 0, 0, 0);
			} loca iacit {
				_pons_iu.communalis().planus2(_mnbr, 0x001, valor, 0, 0, 0, 0);
			} }
			int indentitas { adipisce iacit {
				responde _pons_iu.communalis().planus2(_mnbr, 0x102, 0, 0, 0, 0, 0);
			} loca iacit {
				_pons_iu.communalis().planus2(_mnbr, 0x002, valor, 0, 0, 0, 0);
			} }
			fenestrae.quadrum positus_purus { adipisce iacit {
				fenestrae.quadrum r;
				_pons_iu.communalis().planus2(_mnbr, 0x103, (nintadl)(@r), 0, 0, 0, 0);
				responde r;
			} loca iacit {
				_pons_iu.communalis().planus2(_mnbr, 0x003, (nintadl)(@valor), 0, 0, 0, 0);
			} }
			quadrum positus { adipisce iacit {
				quadrum r;
				_pons_iu.communalis().planus2(_mnbr, 0x104, (nintadl)(@r), 0, 0, 0, 0);
				responde r;
			} loca iacit {
				_pons_iu.communalis().planus2(_mnbr, 0x004, (nintadl)(@valor), 0, 0, 0, 0);
			} }
			linea textum { adipisce iacit {
				linea r;
				_pons_iu.communalis().planus2(_mnbr, 0x105, (nintadl)(@r), 0, 0, 0, 0);
				responde r;
			} loca iacit {
				_pons_iu.communalis().planus2(_mnbr, 0x005, (nintadl)(@valor), 0, 0, 0, 0);
			} }
			logicum tabulum_est { adipisce iacit {
				responde _pons_iu.communalis().planus2(_mnbr, 0x10E, 0, 0, 0, 0, 0);
			} }
			logicum nullum_est { adipisce iacit { responde !_mnbr; } }
			linea nomen_classis { adipisce iacit {
				linea r;
				_pons_iu.communalis().planus2(_mnbr, 0x10F, (nintadl)(@r), 0, 0, 0, 0);
				responde r;
			} }
			functio elementum reperi_filium(int ind) iacit { elementum r; r._mnbr = (@objectum)(_pons_iu.communalis().planus2(_mnbr, 0x20B, ind, 0, 0, 0, 0)); responde r; }
			functio nihil mitte_eventum(nint indent, origo_eventi org, ~elementum missor) iacit { _pons_iu.communalis().planus2(_mnbr, 0x20C, indent, (int)(org), (nintadl)(missor._mnbr.valor()), 0, 0); }
			functio nihil mitte_eventum_deposite(nint indent) iacit { _pons_iu.communalis().planus2(_mnbr, 0x20D, indent, 0, 0, 0, 0); }

			elementum parens { adipisce iacit {
				elementum r;
				r._mnbr = (@objectum)(_pons_iu.communalis().planus2(_mnbr, 0x106, 0, 0, 0, 0, 0));
				responde r;
			} }
			systema_elementorum systema { adipisce iacit {
				systema_elementorum r;
				r._mnbr = (@objectum)(_pons_iu.communalis().planus2(_mnbr, 0x107, 0, 0, 0, 0, 0));
				responde r;
			} }
			@fenestrae.fenestra fenestra { adipisce iacit {
				responde (@fenestrae.fenestra)(_pons_iu.communalis().planus2(_mnbr, 0x108, 0, 0, 0, 0, 0));
			} }
			!ordo elementum filii { adipisce iacit {
				var r = crea(ordo elementum);
				_pons_iu.communalis().planus2(_mnbr, 0x109, (nintadl)(r.valor()), 0, 0, 0, 0);
				responde r;
			} }

			functio nihil ordina(ordo_elementi ord) iacit { _pons_iu.communalis().planus2(_mnbr, 0x200, (int)(ord), 0, 0, 0, 0); }
			functio nihil adde_filium(~elementum filius) iacit { _pons_iu.communalis().planus2(_mnbr, 0x201, (nintadl)(filius._mnbr.valor()), 0, 0, 0, 0); }
			functio nihil remove_filium(~elementum filius) iacit { _pons_iu.communalis().planus2(_mnbr, 0x202, (nintadl)(filius._mnbr.valor()), 0, 0, 0, 0); }
			functio nihil remove_filium(int numerus) iacit { _pons_iu.communalis().planus2(_mnbr, 0x203, numerus, 0, 0, 0, 0); }
			functio nihil remove_ex_parente() iacit { _pons_iu.communalis().planus2(_mnbr, 0x204, 0, 0, 0, 0, 0); }
			functio nihil remove_ex_parente_deposite() iacit { _pons_iu.communalis().planus2(_mnbr, 0x205, 0, 0, 0, 0, 0); }
			functio int numerus_filii(~elementum filius) iacit { responde _pons_iu.communalis().planus2(_mnbr, 0x206, (nintadl)(filius._mnbr.valor()), 0, 0, 0, 0); }
			int numerus_in_parente { adipisce iacit {
				responde _pons_iu.communalis().planus2(_mnbr, 0x10A, 0, 0, 0, 0, 0);
			} }

			fenestrae.quadrum positus_absolutus { adipisce iacit {
				fenestrae.quadrum r;
				_pons_iu.communalis().planus2(_mnbr, 0x10B, (nintadl)(@r), 0, 0, 0, 0);
				responde r;
			} }
			functio logicum parens_elementi_est(~elementum el) iacit { responde _pons_iu.communalis().planus2(_mnbr, 0x207, (nintadl)(el._mnbr.valor()), 0, 0, 0, 0); }
			logicum accessibile { adipisce iacit {
				responde _pons_iu.communalis().planus2(_mnbr, 0x10C, 0, 0, 0, 0, 0);
			} }
			logicum sub_mure { adipisce iacit {
				responde _pons_iu.communalis().planus2(_mnbr, 0x10D, 0, 0, 0, 0, 0);
			} }

			functio nihil move_cum_animatione(~quadrum ad, nint32 tempus, modus_animationis im, modus_animationis fm, actio_animationis act) iacit { _pons_iu.communalis().planus2(_mnbr, 0x20E, (nintadl)(@ad), tempus, (int)(im), (int)(fm), (int)(act)); }
			functio nihil move_cum_animatione(~fenestrae.quadrum ad, nint32 tempus, modus_animationis im, modus_animationis fm, actio_animationis act) iacit { _pons_iu.communalis().planus2(_mnbr, 0x20F, (nintadl)(@ad), tempus, (int)(im), (int)(fm), (int)(act)); }
			functio nihil monstra_cum_animatione(directio_animationis dir, nint32 tempus, modus_animationis im, modus_animationis fm) iacit { _pons_iu.communalis().planus2(_mnbr, 0x210, (int)(dir), tempus, (int)(im), (int)(fm), 0); }
			functio nihil occulta_cum_animatione(directio_animationis dir, nint32 tempus, modus_animationis im, modus_animationis fm) iacit { _pons_iu.communalis().planus2(_mnbr, 0x211, (int)(dir), tempus, (int)(im), (int)(fm), 0); }

			elementum tabulum_proximum { adipisce iacit {
				elementum r;
				r._mnbr = (@objectum)(_pons_iu.communalis().planus2(_mnbr, 0x110, 0, 0, 0, 0, 0));
				responde r;
			} }
			elementum tabulum_pristinum { adipisce iacit {
				elementum r;
				r._mnbr = (@objectum)(_pons_iu.communalis().planus2(_mnbr, 0x111, 0, 0, 0, 0, 0));
				responde r;
			} }

			functio nihil configura_elementum(nint32 sel, modus_ie mod, intadl index, @nihil valor, @nihil genus_valoris) iacit { _pons_iu.communalis().planus2(_mnbr, 0x300, sel, (nint)(mod), index, (nintadl)(valor), (nintadl)(genus_valoris)); }
		}

		protocollum responsor_fenestrae {
			functio nihil fenestra_creata_est(@fenestrae.fenestra fen) iacit virtualis {}
			functio nihil fenestra_deleta_est(@fenestrae.fenestra fen) iacit virtualis {}
			functio nihil fenestra_revelata_est(@fenestrae.fenestra fen, logicum visibilis) iacit virtualis {}
	
			functio nihil expone_fenestram(@fenestrae.fenestra fen) iacit virtualis {}
	
			functio nihil fenestra_closa_est(@fenestrae.fenestra fen) iacit virtualis {}
			functio nihil fenestra_minima_est(@fenestrae.fenestra fen) iacit virtualis {}
			functio nihil fenestra_maxima_est(@fenestrae.fenestra fen) iacit virtualis {}
			functio nihil fenestra_normativa_est(@fenestrae.fenestra fen) iacit virtualis {}
			functio nihil fenestra_suppetia(@fenestrae.fenestra fen) iacit virtualis {}
			functio nihil fenestra_activa_est(@fenestrae.fenestra fen) iacit virtualis {}
			functio nihil fenestra_inactiva_est(@fenestrae.fenestra fen) iacit virtualis {}
	
			functio nihil fenestra_mota_est(@fenestrae.fenestra fen) iacit virtualis {}
			functio nihil fenestra_cressata_est(@fenestrae.fenestra fen) iacit virtualis {}
	
			functio nihil chronometrus_fierit(@fenestrae.fenestra fen) iacit virtualis {}
			functio nihil minutus_cancelatus_est(@fenestrae.fenestra fen) iacit virtualis {}
			functio nihil procede_eventum_internum(@fenestrae.fenestra fen, nint indent, origo_eventi org, ~elementum missor) iacit virtualis {}

			functio nihil thema_mutata_est(@fenestrae.fenestra fen) iacit virtualis {}
			functio logicum eventum_servabile_est(@fenestrae.fenestra fen, fenestrae.eventum_fenestae_globale eve) iacit virtualis { responde non; }
			functio nihil procede_eventum_globale(@fenestrae.fenestra fen, fenestrae.eventum_fenestae_globale eve) iacit virtualis {}
		}
		structura crea_fenestram_desc {
			fenestrae.quadrum positus;
			fenestrae.positus dimensiones_minimae;
			fenestrae.positus dimensiones_maximae;
			fenestrae.quadrum margines_extensi;
			dfrac opacum;
			dfrac macula;
			nint stylus;
			imago.color fundus;
			linea titulus;
			@responsor_fenestrae responsor;
			@fenestrae.fenestra parens;
			adl[fenestrae.culicare] culicare;
			logicum thema_tenebrosa;
		}

		structura decoratio_systemae_elementorum {
			int magnitudo_marginis_minuti;
			int magnitudo_elementi_minuti;
			int magnitudo_delimitatoris_minuti;
			!graphicum.typographica typographica_minuti;
			!visualis_incompletus umbra_minuti;
			!visualis_incompletus fundus_minuti;
			!visualis_incompletus spiculum_minuti;
			!visualis_incompletus delimitator_minuti;
			!visualis_incompletus elementum_minuti_normativum;
			!visualis_incompletus elementum_minuti_inabile;
			!visualis_incompletus elementum_minuti_selectum;
			!visualis_incompletus elementum_minuti_normativum_designatum;
			!visualis_incompletus elementum_minuti_inabile_designatum;
			!visualis_incompletus elementum_minuti_selectum_designatum;
		}
		dura systema_elementorum {
			int magnitudo_cursoris { adipisce iacit {
				responde _pons_iu.communalis().planus1(_mnbr, 0x100, 0, 0, 0, 0, 0);
			} loca iacit {
				_pons_iu.communalis().planus1(_mnbr, 0x000, (intadl)(valor), 0, 0, 0, 0);
