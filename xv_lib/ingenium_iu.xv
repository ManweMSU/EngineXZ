		enumeratio imperata_acceleratorum_systemae { clode_fenestram = 0, suppetia = 1, elementum_proximum = 2, elementum_pristinum = 3 }
		structura accelerator {
			int imperatum;
			tactus tactus;
			logicum shift;
			logicum control;
			logicum alternative;
			logicum imperata_systemae_est;

			structor () {}
			structor (.tactus tc, logicum sft, logicum ctrl, logicum alt, int imp, logicum sys) { funda tactus(tc); funda shift(sft); funda control(ctrl); funda alternative(alt); funda imperatum(imp); funda imperata_systemae_est(sys); }
		}

