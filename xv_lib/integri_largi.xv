	}
	[[xa]] [[convertor] "angustans"] structor (int256 org)
	{
		INTERFACE W 1 : THIS 32 : OBJECT => 0
		CODE { RET { @L_MOV:16 16=>0(@PTR_FOLLOW:W 1=>16(A[0]), A[1]) } }
	}
	[[xa]] [[convertor] "angustans"] structor (nint256 org)
	{
		INTERFACE W 1 : THIS 32 : OBJECT => 0
		CODE { RET { @L_MOV:16 16=>0(@PTR_FOLLOW:W 1=>16(A[0]), A[1]) } }
	}
	[[convertor] "pretiosus"] structor (frac org)
	{
		var S = (@nint32)(@org)^ >> 31;
		var E = ((@nint32)(@org)^ >> 23) & 0xFF;
		var V = (@nint32)(@org)^ & 0x7FFFFF;
		si (E) V |= 0x800000; alioqui E++;
		int R = E - 0x7F - 23;
		si (E == 0xFF || R >= 104) {
			ego^ = int128(0x80) << 120;
			si (!S) ego^--;
		} alioqui {
			si (R >= 0) ego^ = int128(V) << R; alioqui ego^ = int128(V) >> -R;
			si (S) ego^ = -ego^;
		}
	}
	[[convertor] "pretiosus"] structor (dfrac org)
	{
		var S = (@nint64)(@org)^ >> 63;
		var E = ((@nint64)(@org)^ >> 52) & 0x7FF;
		var V = (@nint64)(@org)^ & 0x000FFFFFFFFFFFFF;
		si (E) V |= 0x0010000000000000; alioqui E++;
		int R = E - 0x3FF - 52;
		si (E == 0x7FF || R >= 75) {
			ego^ = int128(0x80) << 120;
			si (!S) ego^--;
		} alioqui {
			si (R >= 0) ego^ = int128(V) << R; alioqui ego^ = int128(V) >> -R;
			si (S) ego^ = -ego^;
		}
	}

	functio nihil _ini_ex_linea(~linea data, ~linea radix, logicum sensitivus) iacit
	{
		si (data[0] == '-') {
			(@nint128)(ego)^._ini_ex_linea(data.fragmentum(1, -1), radix, sensitivus);
			ego^ = -ego^;
			si (ego^ > int128(0)) iace errores.efformatio_falsa;
		} alioqui si (data[0] == '+') {
			(@nint128)(ego)^._ini_ex_linea(data.fragmentum(1, -1), radix, sensitivus);
			si (ego^ < int128(0)) iace errores.efformatio_falsa;
		} alioqui {
			(@nint128)(ego)^._ini_ex_linea(data, radix, sensitivus);
			si (ego^ < int128(0)) iace errores.efformatio_falsa;
		}
	}
	[[convertor] "angustans"] structor (~linea data) iacit { _ini_ex_linea(data, linea.radix_decima, sic); }
	structor (~linea data, ~linea radix) iacit { _ini_ex_linea(data, radix, non); }
	structor (~linea data, ~linea radix, logicum sensitivus) iacit { _ini_ex_linea(data, radix, sensitivus); }

	[[xa]] [[convertor] "angustans"] convertor (logicum) () { INTERFACE W 1 : THIS => 1 : UINT DATA { QWORD 0 QWORD 0 } CODE { RET { @BLT:1 1=>1(R, @L_NEQ:16 16=>1(@PTR_FOLLOW:W 1=>16(A[0]), D[0])) } } }
	[[xa]] [[convertor] "angustans"] convertor (int8) () { INTERFACE W 1 : THIS => 1 : SINT CODE { RET{ @BLT:1 1=>1(R, @PTR_FOLLOW:W 1=>1(A[0])) } } }
	[[xa]] [[convertor] "angustans"] convertor (nint8) () { INTERFACE W 1 : THIS => 1 : UINT CODE { RET{ @BLT:1 1=>1(R, @PTR_FOLLOW:W 1=>1(A[0])) } } }
	[[xa]] [[convertor] "angustans"] convertor (int16) () { INTERFACE W 1 : THIS => 2 : SINT CODE { RET{ @BLT:2 2=>2(R, @PTR_FOLLOW:W 1=>2(A[0])) } } }
	[[xa]] [[convertor] "angustans"] convertor (nint16) () { INTERFACE W 1 : THIS => 2 : UINT CODE { RET{ @BLT:2 2=>2(R, @PTR_FOLLOW:W 1=>2(A[0])) } } }
	[[xa]] [[convertor] "angustans"] convertor (int32) () { INTERFACE W 1 : THIS => 4 : SINT CODE { RET{ @BLT:4 4=>4(R, @PTR_FOLLOW:W 1=>4(A[0])) } } }
	[[xa]] [[convertor] "angustans"] convertor (nint32) () { INTERFACE W 1 : THIS => 4 : UINT CODE { RET{ @BLT:4 4=>4(R, @PTR_FOLLOW:W 1=>4(A[0])) } } }
	[[xa]] [[convertor] "angustans"] convertor (int64) () { INTERFACE W 1 : THIS => 8 : SINT CODE { RET{ @BLT:8 8=>8(R, @PTR_FOLLOW:W 1=>8(A[0])) } } }
	[[xa]] [[convertor] "angustans"] convertor (nint64) () { INTERFACE W 1 : THIS => 8 : UINT CODE { RET{ @BLT:8 8=>8(R, @PTR_FOLLOW:W 1=>8(A[0])) } } }
	[[xa]] [[convertor] "angustans"] convertor (intadl) () { INTERFACE W 1 : THIS => W 1 : SINT CODE { RET{ @BLT:W 1 W 1=>W 1(R, @PTR_FOLLOW:W 1=>W 1(A[0])) } } }
	[[xa]] [[convertor] "angustans"] convertor (nintadl) () { INTERFACE W 1 : THIS => W 1 : UINT CODE { RET{ @BLT:W 1 W 1=>W 1(R, @PTR_FOLLOW:W 1=>W 1(A[0])) } } }
	convertor (frac) () {
		nint32 r = 0;
		var V = ego^;
		var S = V < 0;
		si (S) V = -V;
		si (V) {
			int E = 0;
			genus(ego^) MX = 0x1000000, MN = 0x800000;
			dum (V >= MX) { V >>= 1; E++; }
			dum (V < MN) { V <<= 1; E--; }
			si (E + 0x7F + 23 >= 0xFF) r = 0x7F800000; alioqui {
				r = genus(r)(V) & 0x7FFFFF;
				r |= (genus(r)(E + 0x7F + 23) & 0xFF) << 23;
			}
			si (S) r |= 0x80000000;
		}
		responde (@frac)(@r)^;
	}
	convertor (dfrac) () {
		nint64 r = 0;
		var V = ego^;
		var S = V < 0;
		si (S) V = -V;
		si (V) {
			int E = 0;
			genus(ego^) MX = 0x0020000000000000, MN = 0x0010000000000000;
			dum (V >= MX) { V >>= 1; E++; }
			dum (V < MN) { V <<= 1; E--; }
			si (E + 0x3FF + 52 >= 0x7FF) r = 0x7FF0000000000000; alioqui {
				r = genus(r)(V) & 0x000FFFFFFFFFFFFF;
				r |= (genus(r)(E + 0x3FF + 52) & 0x7FF) << 52;
			}
			si (S) r |= 0x8000000000000000;
		}
		responde (@dfrac)(@r)^;
