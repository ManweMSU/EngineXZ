	functio linea ad_lineam(~linea radix, int long_min) iacit
	{
		si (ego^ < int128(0)) responde "-" + nint128(-ego^).ad_lineam(radix, long_min);
		alioqui responde nint128(ego^).ad_lineam(radix, long_min);
	}
