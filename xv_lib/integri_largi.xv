	}
	[[xa]] [[convertor] "extendens"] structor (nint64 org)
	{
		INTERFACE W 1 : THIS 8 : UINT => 0
		CODE { RET { @L_ZERO:16 8=>0(@PTR_FOLLOW:W 1=>16(A[0]), A[1]) } }
	}
	[[xa]] [[convertor] "extendens"] structor (intadl org)
	{
		EXTERNAL "S:int128.>>=:F(RCint128)(Cint128)" DATA DWORD 64
		INTERFACE W 1 : THIS W 1 : SINT => 0
		CODE {
			EVAL { @L_ZERO:16 8 8=>0(@PTR_FOLLOW:W 1=>16(A[0]), @S_RESIZE:W 1=>8(A[1]), -) }
			ENTER
			NEW { @L_ZERO:16 4=>0(I, D[0]) } @ 16
			RET { E[0]:W 1:THIS 16:OBJECT=>W 1(A[0], L[0]) }
			LEAVE
		}
	}
	[[xa]] [[convertor] "extendens"] structor (nintadl org)
	{
		INTERFACE W 1 : THIS W 1 : UINT => 0
		CODE { RET { @L_ZERO:16:- W 1=>0(@PTR_FOLLOW:W 1=>16(A[0]), A[1]) } }
	}
	[[xa]] [[convertor] "conformis"] structor (nint128 org)
	{
		INTERFACE W 1 : THIS 16 : OBJECT => 0
