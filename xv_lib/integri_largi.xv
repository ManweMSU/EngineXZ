	convertor (frac) () {
		nint32 r = 0;
		var V = ego^;
		var S = V < 0;
		si (S) V = -V;
		si (V) {
			int E = 0;
			genus(ego^) MX = 0x1000000, MN = 0x800000;
			dum (V >= MX) { V >>= 1; E++; }
			dum (V < MN) { V <<= 1; E--; }
			si (E + 0x7F + 23 >= 0xFF) r = 0x7F800000; alioqui {
				r = genus(r)(V) & 0x7FFFFF;
				r |= (genus(r)(E + 0x7F + 23) & 0xFF) << 23;
			}
			si (S) r |= 0x80000000;
		}
		responde (@frac)(@r)^;
	}
	convertor (dfrac) () {
		nint64 r = 0;
		var V = ego^;
		var S = V < 0;
		si (S) V = -V;
		si (V) {
			int E = 0;
			genus(ego^) MX = 0x0020000000000000, MN = 0x0010000000000000;
			dum (V >= MX) { V >>= 1; E++; }
			dum (V < MN) { V <<= 1; E--; }
			si (E + 0x3FF + 52 >= 0x7FF) r = 0x7FF0000000000000; alioqui {
				r = genus(r)(V) & 0x000FFFFFFFFFFFFF;
				r |= (genus(r)(E + 0x3FF + 52) & 0x7FF) << 52;
			}
			si (S) r |= 0x8000000000000000;
		}
		responde (@dfrac)(@r)^;
	}

	[[inline]] [[convertor] "extendens:pretiosus"] convertor (linea) () iacit { responde ad_lineam(linea.radix_decima, 0); }
	[[inline]] functio linea ad_lineam() iacit { responde ad_lineam(linea.radix_decima, 0); }
	[[inline]] functio linea ad_lineam(~linea radix) iacit { responde ad_lineam(radix, 0); }
	functio linea ad_lineam(~linea radix, int long_min) iacit
	{
		si (ego^ < int256(0)) responde "-" + nint256(-ego^).ad_lineam(radix, long_min);
		alioqui responde nint256(ego^).ad_lineam(radix, long_min);
	}
