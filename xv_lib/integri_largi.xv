[[magnitudo] "16"] genus int128 {
	[serializa_semper] [nomen_serializandi data] [[positus] "0"] ordo [4] nint32 _data;
	[[xa]] structor () {
		INTERFACE W 1 : THIS => 0
		CODE { RET }
	}
	[[xa]] structor (int128 org) {
		INTERFACE W 1 : THIS 16 : OBJECT => 0
		CODE { RET { @L_MOV:16 16=>0(@PTR_FOLLOW:W 1=>16(A[0]), A[1]) } }
	}
	[[xa]] functio int128 operator - () {
		INTERFACE W 1 : THIS => 16 : OBJECT
		CODE { EVAL { @L_ZERO:16=>0(R) } RET { @L_SUB:16 16=>0(R, @PTR_FOLLOW:W 1=>16(A[0])) } }
	}
	functio int128 operator ~ () {
		int128 r;
		r._data[0] = ~_data[0]; r._data[1] = ~_data[1]; r._data[2] = ~_data[2]; r._data[3] = ~_data[3];
		responde r;
	}
	functio logicum operator ! () {
		responde _data[0] == 0 && _data[1] == 0 && _data[2] == 0 && _data[3] == 0;
	}
	[[xa]] functio ~int128 operator = (int128 org) {
		INTERFACE W 1 : THIS 16 : OBJECT => W 1
		CODE { EVAL { @L_MOV:16 16=>0(@PTR_FOLLOW:W 1=>16(A[0]), A[1]) } RET { @BLT:W 1 W 1=>W 1(R, A[0]) } }
	}
	[[xa]] functio ~int128 operator += (int128 org) {
		INTERFACE W 1 : THIS 16 : OBJECT => W 1
		CODE { EVAL { @L_ADD:16 16=>0(@PTR_FOLLOW:W 1=>16(A[0]), A[1]) } RET { @BLT:W 1 W 1=>W 1(R, A[0]) } }
	}
	[[xa]] functio ~int128 operator -= (int128 org) {
		INTERFACE W 1 : THIS 16 : OBJECT => W 1
		CODE { EVAL { @L_SUB:16 16=>0(@PTR_FOLLOW:W 1=>16(A[0]), A[1]) } RET { @BLT:W 1 W 1=>W 1(R, A[0]) } }
	}
	functio ~int128 operator *= (int128 org) { ego^ = ego^ * org; responde ego^; }
	functio ~int128 operator /= (int128 org) { ego^ = ego^ / org; responde ego^; }
	functio ~int128 operator %= (int128 org) { ego^ = ego^ % org; responde ego^; }
	functio ~int128 operator |= (int128 org) {
		_data[0] |= org._data[0];
		_data[1] |= org._data[1];
		_data[2] |= org._data[2];
		_data[3] |= org._data[3];
		responde ego^;
	}
	functio ~int128 operator &= (int128 org) {
		_data[0] &= org._data[0];
		_data[1] &= org._data[1];
		_data[2] &= org._data[2];
		_data[3] &= org._data[3];
		responde ego^;
	}
	functio ~int128 operator #= (int128 org) {
		_data[0] #= org._data[0];
		_data[1] #= org._data[1];
		_data[2] #= org._data[2];
		_data[3] #= org._data[3];
		responde ego^;
	}
	[[xa]] functio ~int128 operator <<= (int128 org) {
		INTERFACE W 1 : THIS 16 : OBJECT => W 1
		DATA {
			QWORD 0x7F QWORD 0 ; MAXIMAL ROTATION
			DWORD 1
		}
		CODE {
			; ZERO ON LARGE SHIFT
			JUMPIF { @L_LE:16 16=>1(A[1], D[0]) } @ 2
			EVAL { @L_ZERO:16=>0(@PTR_FOLLOW:W 1=>16(A[0])) }
			RET { @BLT:W 1 W 1=>W 1(R, A[0]) }
			; INIT COUNTER
			ENTER
			NEW { @BLT:4 4=>4(I, A[1]) } @ 4
			; LOOP WHILE COUNTER > 0
			JUMPIF { @ZERO:4=>4(L[0]) } @ 3
			EVAL { @L_SHL:16 1=>0(@PTR_FOLLOW:W 1=>16(A[0]), -) }
			EVAL { @BLT:4 4=>4(L[0], @SUB:4 4=>4(L[0], D[16])) }
			JUMP @ -4
			LEAVE
			RET { @BLT:W 1 W 1=>W 1(R, A[0]) }
		}
	}
	[[xa]] functio ~int128 operator >>= (int128 org) {
		INTERFACE W 1 : THIS 16 : OBJECT => W 1
		DATA {
			QWORD 0x7F QWORD 0 ; MAXIMAL ROTATION
			DWORD 1
		}
		CODE {
			; INIT COUNTER
			ENTER
			NEW { @BLT:4 4=>4(I, A[1]) } @ 4
			; CLAMP COUNTER TO MAXIMAL SHIFT
			JUMPIF { @L_LE:16 16=>1(A[1], D[0]) } @ 1
			EVAL { @BLT:4 4=>4(L[0], D[0]) }
			; INPUT BACKUP FOR SIGN REPLICATION
			NEW { @L_MOV:16 16=>0(I, @PTR_FOLLOW:W 1=>16(A[0])) } @ 16
			; LOOP WHILE COUNTER > 0
			JUMPIF { @ZERO:4=>4(L[0]) } @ 4
			EVAL { @L_SHR:16 1=>0(@PTR_FOLLOW:W 1=>16(A[0]), -) }
			EVAL { @L_SET:16 4 1=>0(@PTR_FOLLOW:W 1=>16(A[0]), D[0], @L_BIT:16 4=>1(L[1], D[0])) }
			EVAL { @BLT:4 4=>4(L[0], @SUB:4 4=>4(L[0], D[16])) }
			JUMP @ -5
			LEAVE
			RET { @BLT:W 1 W 1=>W 1(R, A[0]) }
		}
	}
	[[xa]] functio ~int128 operator ++ () {
		INTERFACE W 1 : THIS => W 1
		DATA { QWORD 1 QWORD 0 }
		CODE { EVAL { @L_ADD:16 16=>0(@PTR_FOLLOW:W 1=>16(A[0]), D[0]) } RET { @BLT:W 1 W 1=>W 1(R, A[0]) } }
	}
	[[xa]] functio ~int128 operator -- () {
		INTERFACE W 1 : THIS => W 1
		DATA { QWORD 1 QWORD 0 }
		CODE { EVAL { @L_SUB:16 16=>0(@PTR_FOLLOW:W 1=>16(A[0]), D[0]) } RET { @BLT:W 1 W 1=>W 1(R, A[0]) } }
	}
	[[xa]] classis functio int128 operator + (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 16 : OBJECT
		CODE { EVAL { @L_MOV:16 16=>0(R, A[0]) } RET { @L_ADD:16 16=>0(R, A[1]) } }
	}
	[[xa]] classis functio int128 operator - (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 16 : OBJECT
		CODE { EVAL { @L_MOV:16 16=>0(R, A[0]) } RET { @L_SUB:16 16=>0(R, A[1]) } }
	}
	[[xa]] classis functio int128 operator * (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 16 : OBJECT
		CODE {
			ENTER
			EVAL { @L_MOV:16 16=>0(R, A[0]) }
			EVAL { @L_MUL:16 4=>4(R, A[1]) }
			NEW { @L_ZERO:16 16 4=>0(I, A[0], -) } @ 16
			EVAL { @L_MUL:16 4=>4(L[0], @OFFSET:16 4=>4(A[1], -)) }
			EVAL { @L_ADD:16 16=>0(R, L[0]) }
			EVAL { @L_ZERO:16 16 8=>0(L[0], A[0], -) }
			EVAL { @L_MUL:16 4=>4(L[0], @OFFSET:16 8=>4(A[1], -)) }
			EVAL { @L_ADD:16 16=>0(R, L[0]) }
			EVAL { @L_ZERO:16 16 12=>0(L[0], A[0], -) }
			EVAL { @L_MUL:16 4=>4(L[0], @OFFSET:16 12=>4(A[1], -)) }
			RET { @L_ADD:16 16=>0(R, L[0]) }
			LEAVE
		}
	}
	classis functio int128 operator / (int128 a, int128 b) {
		int128 div = a, d = b;
		logicum sdiv = non;
		si (d._data[3] & 0x80000000) { div = -div; d = -d; }
		si (div._data[3] & 0x80000000) { div = -div; sdiv = sic; }
		(@nint128)(@div)^._div_mod((@nint128)(@d)^);
		si (sdiv) responde -div; alioqui responde div;
	}
	classis functio int128 operator % (int128 a, int128 b) {
		int128 div = a, d = b;
		logicum smod = non;
		si (d._data[3] & 0x80000000) { div = -div; d = -d; smod = sic; }
		si (div._data[3] & 0x80000000) { div = -div; smod = !smod; }
		nint128 mod = (@nint128)(@div)^._div_mod((@nint128)(@d)^);
		si (smod) mod = -mod;
		responde (@int128)(@mod)^;
	}
	[[xa]] classis functio int128 operator | (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 16 : OBJECT
		CODE {
			EVAL { @BLT:8 8=>8(R, @OR:8 8=>8(A[0], A[1])) }
			RET { @BLT:8 8=>8(@OFFSET:16 8=>8(R, -), @OR:8 8=>8(@OFFSET:16 8=>8(A[0], -), @OFFSET:16 8=>8(A[1], -))) }
		}
	}
	[[xa]] classis functio int128 operator & (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 16 : OBJECT
		CODE {
			EVAL { @BLT:8 8=>8(R, @AND:8 8=>8(A[0], A[1])) }
			RET { @BLT:8 8=>8(@OFFSET:16 8=>8(R, -), @AND:8 8=>8(@OFFSET:16 8=>8(A[0], -), @OFFSET:16 8=>8(A[1], -))) }
		}
	}
	[[xa]] classis functio int128 operator # (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 16 : OBJECT
		CODE {
			EVAL { @BLT:8 8=>8(R, @XOR:8 8=>8(A[0], A[1])) }
			RET { @BLT:8 8=>8(@OFFSET:16 8=>8(R, -), @XOR:8 8=>8(@OFFSET:16 8=>8(A[0], -), @OFFSET:16 8=>8(A[1], -))) }
		}
	}
	classis functio int128 operator << (int128 a, int128 b) { var r = a; responde r <<= b; }
	classis functio int128 operator >> (int128 a, int128 b) { var r = a; responde r >>= b; }
	[[xa]] classis functio logicum operator == (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 1
		CODE { RET { @BLT:1 1=>1(R, @L_EQ:16 16=>1(A[0], A[1])) } }
	}
	[[xa]] classis functio logicum operator != (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 1
		CODE { RET { @BLT:1 1=>1(R, @L_NEQ:16 16=>1(A[0], A[1])) } }
	}
	[[xa]] classis functio logicum operator < (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 1
		DATA { QWORD 0 QWORD 0x8000000000000000 }
		CODE {
			ENTER
			NEW { @L_MOV:16 16=>0(I, A[0]) } @ 16
			NEW { @L_MOV:16 16=>0(I, A[1]) } @ 16
			EVAL { @L_ADD:16 16=>0(L[0], D[0]) }
			EVAL { @L_ADD:16 16=>0(L[1], D[0]) }
			RET { @BLT:1 1=>1(R, @L_L:16 16=>1(L[0], L[1])) }
			LEAVE
		}
	}
	[[xa]] classis functio logicum operator > (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 1
		DATA { QWORD 0 QWORD 0x8000000000000000 }
		CODE {
			ENTER
			NEW { @L_MOV:16 16=>0(I, A[0]) } @ 16
			NEW { @L_MOV:16 16=>0(I, A[1]) } @ 16
			EVAL { @L_ADD:16 16=>0(L[0], D[0]) }
			EVAL { @L_ADD:16 16=>0(L[1], D[0]) }
			RET { @BLT:1 1=>1(R, @L_G:16 16=>1(L[0], L[1])) }
			LEAVE
		}
	}
	[[xa]] classis functio logicum operator <= (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 1
		DATA { QWORD 0 QWORD 0x8000000000000000 }
		CODE {
			ENTER
			NEW { @L_MOV:16 16=>0(I, A[0]) } @ 16
			NEW { @L_MOV:16 16=>0(I, A[1]) } @ 16
			EVAL { @L_ADD:16 16=>0(L[0], D[0]) }
			EVAL { @L_ADD:16 16=>0(L[1], D[0]) }
			RET { @BLT:1 1=>1(R, @L_LE:16 16=>1(L[0], L[1])) }
			LEAVE
		}
	}
	[[xa]] classis functio logicum operator >= (int128 a, int128 b) {
		INTERFACE 16 : OBJECT 16 : OBJECT => 1
		DATA { QWORD 0 QWORD 0x8000000000000000 }
		CODE {
			ENTER
			NEW { @L_MOV:16 16=>0(I, A[0]) } @ 16
			NEW { @L_MOV:16 16=>0(I, A[1]) } @ 16
			EVAL { @L_ADD:16 16=>0(L[0], D[0]) }
			EVAL { @L_ADD:16 16=>0(L[1], D[0]) }
			RET { @BLT:1 1=>1(R, @L_GE:16 16=>1(L[0], L[1])) }
			LEAVE
		}
	}
}
