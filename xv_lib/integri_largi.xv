			dum (V >= MX) { V >>= 1; E++; }
			dum (V < MN) { V <<= 1; E--; }
			si (E + 0x3FF + 52 >= 0x7FF) r = 0x7FF0000000000000; alioqui {
				r = genus(r)(V) & 0x000FFFFFFFFFFFFF;
				r |= (genus(r)(E + 0x3FF + 52) & 0x7FF) << 52;
