	[[inline]] [[convertor] "extendens:pretiosus"] convertor (linea) () iacit { responde ad_lineam(linea.radix_decima, 0); }
	[[inline]] functio linea ad_lineam() iacit { responde ad_lineam(linea.radix_decima, 0); }
	[[inline]] functio linea ad_lineam(~linea radix) iacit { responde ad_lineam(radix, 0); }
	functio linea ad_lineam(~linea radix, int long_min) iacit
	{
		ordo char rdx, dest;
		rdx.longitudo = radix.longitudo_codicis(linea.codex.utf32);
		radix.codifica(rdx.data, linea.codex.utf32, non);
		int l = long_min;
		var R = rdx.longitudo;
		si (l <= 0) l = 1;
		si (rdx.longitudo < 2) iace errores.argumentum_falsum;
		nint256 n(ego^);
		dum (n) { var r = n._div_mod(R); dest.adde(rdx[r]); }
		dum (dest.longitudo < l) dest.adde(rdx[0]);
		R = dest.longitudo - 1;
		l = dest.longitudo / 2 - 1;
		per (var i : [0, l]) dest.permuta(i, R - i);
		responde linea(dest.data, dest.longitudo, linea.codex.utf32);
	}
}

spatium math {
	functio int128 abs(int128 valor) { responde valor < 0 ? -valor : valor; }
	functio int256 abs(int256 valor) { responde valor < 0 ? -valor : valor; }
	functio int128 sgn(int128 valor) { responde valor < 0 ? -1 : valor > 0 ? 1 : 0; }
	functio int256 sgn(int256 valor) { responde valor < 0 ? -1 : valor > 0 ? 1 : 0; }
}