	[[convertor] "pretiosus"] structor (frac org)
	{
		var S = (@nint32)(@org)^ >> 31;
		var E = ((@nint32)(@org)^ >> 23) & 0xFF;
		var V = (@nint32)(@org)^ & 0x7FFFFF;
		si (E) V |= 0x800000; alioqui E++;
		int R = E - 0x7F - 23;
		si (E == 0xFF || R >= 233) {
			ego^ = nint256(0);
			si (!S) ego^--;
		} alioqui {
			si (R >= 0) ego^ = nint256(V) << R; alioqui ego^ = nint256(V) >> -R;
			si (S) ego^ = nint256(0);
		}
	}
	[[convertor] "pretiosus"] structor (dfrac org)
	{
		var S = (@nint64)(@org)^ >> 63;
		var E = ((@nint64)(@org)^ >> 52) & 0x7FF;
		var V = (@nint64)(@org)^ & 0x000FFFFFFFFFFFFF;
		si (E) V |= 0x0010000000000000; alioqui E++;
		int R = E - 0x3FF - 52;
		si (E == 0x7FF || R >= 204) {
			ego^ = nint256(0);
			si (!S) ego^--;
		} alioqui {
			si (R >= 0) ego^ = nint256(V) << R; alioqui ego^ = nint256(V) >> -R;
			si (S) ego^ = nint256(0);
		}
	}

	functio nihil _ini_ex_linea(~linea data, ~linea radix, logicum sensitivus) iacit
	{
		memoria.relabe(@_data, magnitudo(_data));
		ordo char data32, radix32;
		si (sensitivus) {
			data32.longitudo = data.longitudo_codicis(linea.codex.utf32);
			radix32.longitudo = radix.longitudo_codicis(linea.codex.utf32);
			data.codifica(data32.data, linea.codex.utf32, non);
			radix.codifica(radix32.data, linea.codex.utf32, non);
		} alioqui {
			var data_inf = data.inferna;
			var radix_inf = radix.inferna;
			data32.longitudo = data_inf.longitudo_codicis(linea.codex.utf32);
			radix32.longitudo = radix_inf.longitudo_codicis(linea.codex.utf32);
			data_inf.codifica(data32.data, linea.codex.utf32, non);
			radix_inf.codifica(radix32.data, linea.codex.utf32, non);
		}
		var R = radix32.longitudo;
		si (R < 2) iace errores.argumentum_falsum;
		var ~ n = ego^ = 0;
		per (var i : data32) {
			nint j = 0;
			dum (j < R && radix32[j] != data32[i]) j++;
			si (j == R) iace errores.efformatio_falsa;
			si (n._mul(R) || n._adde(j)) iace errores.efformatio_falsa;
		}
	}
	[[convertor] "angustans"] structor (~linea data) iacit { _ini_ex_linea(data, linea.radix_decima, sic); }
	structor (~linea data, ~linea radix) iacit { _ini_ex_linea(data, radix, non); }
	structor (~linea data, ~linea radix, logicum sensitivus) iacit { _ini_ex_linea(data, radix, sensitivus); }

