		INTERFACE W 1 : THIS 4 : UINT => 4 : UINT
		CODE { RET { @BLT:4 4=>4(R, @L_DIV:16 4=>4(@PTR_FOLLOW:W 1=>16(A[0]), A[1])) } }
	}
	[[xa]] functio nint128 _div_mod(nint128 b) {
		INTERFACE W 1 : THIS 16 : OBJECT => 16 : OBJECT
		DATA { QWORD 0 QWORD 0 DWORD 127 DWORD 1 }
		CODE {
			ENTER
			; R <- A[0], L[0] <- A[1]
			EVAL { @L_MOV:16 16=>0(R, @PTR_FOLLOW:W 1=>16(A[0])) }
			NEW { @L_MOV:16 16=>0(I, A[1]) } @ 16
			NEW { @L_ZERO:4=>0(I) } @ 4
			; CHECK DIVISION BY ZERO
			JUMPIF { @L_NEQ:16 16=>1(L[0], D[0]) } @ 1
			TRAP
			; L[0] <- L[0] << N: BIT(L[0], 127) == 1; L[1] <- N
			JUMPIF { @L_BIT:16 4=>1(L[0], D[16]) } @ 3
			EVAL { @L_SHL:16 1=>0(L[0], -) }
			EVAL { @BLT:4 4=>4(L[1], @ADD:4 4=>4(L[1], D[20])) }
			JUMP @ -4
			; CLEAR A[0]
			EVAL { @L_ZERO:16=>0(@PTR_FOLLOW:W 1=>16(A[0])) }
			; LOOP WHILE R >= A[1]
			JUMPIF { @L_L:16 16=>1(R, A[1]) } @ 6
			; IF L[0] <= R THE SET THE Nth BIT IN A[0], R <- R - L[0]
			JUMPIF { @L_L:16 16=>1(R, L[0]) } @ 2
			EVAL { @L_SUB:16 16=>0(R, L[0]) }
			EVAL { @L_SET:16 4 4=>0(@PTR_FOLLOW:W 1=>16(A[0]), L[1], D[20]) }
			; L[0] <- L[0] >> 1; N--
			EVAL { @L_SHR:16 1=>0(L[0], -) }
			EVAL { @BLT:4 4=>4(L[1], @SUB:4 4=>4(L[1], D[20])) }
			; LOOP BACK
			JUMP @ -7
			RET
			LEAVE
		}
	}
}
