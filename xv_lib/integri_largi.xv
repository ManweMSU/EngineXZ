		_data[2] &= org._data[2];
		_data[3] &= org._data[3];
		_data[4] &= org._data[4];
		_data[5] &= org._data[5];
		_data[6] &= org._data[6];
		_data[7] &= org._data[7];
		responde ego^;
	}
	functio ~nint256 operator #= (nint256 org) {
		_data[0] #= org._data[0];
		_data[1] #= org._data[1];
		_data[2] #= org._data[2];
		_data[3] #= org._data[3];
		_data[4] #= org._data[4];
		_data[5] #= org._data[5];
		_data[6] #= org._data[6];
		_data[7] #= org._data[7];
		responde ego^;
	}
	[[xa]] functio ~nint256 operator <<= (nint256 org) {
		INTERFACE W 1 : THIS 32 : OBJECT => W 1
		DATA {
			QWORD 0xFF QWORD 0 QWORD 0 QWORD 0 ; MAXIMAL ROTATION
			DWORD 1
		}
		CODE {
			; ZERO ON LARGE SHIFT
			JUMPIF { @L_LE:32 32=>1(A[1], D[0]) } @ 2
			EVAL { @L_ZERO:32=>0(@PTR_FOLLOW:W 1=>32(A[0])) }
			RET { @BLT:W 1 W 1=>W 1(R, A[0]) }
			; INIT COUNTER
			ENTER
			NEW { @BLT:4 4=>4(I, A[1]) } @ 4
			; LOOP WHILE COUNTER > 0
			JUMPIF { @ZERO:4=>4(L[0]) } @ 3
			EVAL { @L_SHL:32 1=>0(@PTR_FOLLOW:W 1=>32(A[0]), -) }
			EVAL { @BLT:4 4=>4(L[0], @SUB:4 4=>4(L[0], D[32])) }
			JUMP @ -4
			LEAVE
			RET { @BLT:W 1 W 1=>W 1(R, A[0]) }
		}
	}
	[[xa]] functio ~nint256 operator >>= (nint256 org) {
		INTERFACE W 1 : THIS 32 : OBJECT => W 1
		DATA {
			QWORD 0xFF QWORD 0 QWORD 0 QWORD 0 ; MAXIMAL ROTATION
			DWORD 1
		}
		CODE {
			; ZERO ON LARGE SHIFT
			JUMPIF { @L_LE:32 32=>1(A[1], D[0]) } @ 2
			EVAL { @L_ZERO:32=>0(@PTR_FOLLOW:W 1=>32(A[0])) }
			RET { @BLT:W 1 W 1=>W 1(R, A[0]) }
			; INIT COUNTER
			ENTER
			NEW { @BLT:4 4=>4(I, A[1]) } @ 4
			; LOOP WHILE COUNTER > 0
			JUMPIF { @ZERO:4=>4(L[0]) } @ 3
			EVAL { @L_SHR:32 1=>0(@PTR_FOLLOW:W 1=>32(A[0]), -) }
			EVAL { @BLT:4 4=>4(L[0], @SUB:4 4=>4(L[0], D[32])) }
			JUMP @ -4
			LEAVE
			RET { @BLT:W 1 W 1=>W 1(R, A[0]) }
		}
	}
	[[xa]] functio ~nint256 operator ++ () {
		INTERFACE W 1 : THIS => W 1
		DATA { QWORD 1 QWORD 0 QWORD 0 QWORD 0 }
		CODE { EVAL { @L_ADD:32 32=>0(@PTR_FOLLOW:W 1=>32(A[0]), D[0]) } RET { @BLT:W 1 W 1=>W 1(R, A[0]) } }
	}
	[[xa]] functio ~nint256 operator -- () {
		INTERFACE W 1 : THIS => W 1
		DATA { QWORD 1 QWORD 0 QWORD 0 QWORD 0 }
		CODE { EVAL { @L_SUB:32 32=>0(@PTR_FOLLOW:W 1=>32(A[0]), D[0]) } RET { @BLT:W 1 W 1=>W 1(R, A[0]) } }
	}
	[[xa]] classis functio nint256 operator + (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 32 : OBJECT
		CODE { EVAL { @L_MOV:32 32=>0(R, A[0]) } RET { @L_ADD:32 32=>0(R, A[1]) } }
	}
	[[xa]] classis functio nint256 operator - (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 32 : OBJECT
		CODE { EVAL { @L_MOV:32 32=>0(R, A[0]) } RET { @L_SUB:32 32=>0(R, A[1]) } }
	}
	[[xa]] classis functio nint256 operator * (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 32 : OBJECT
		CODE {
			ENTER
			EVAL { @L_MOV:32 32=>0(R, A[0]) }
			EVAL { @L_MUL:32 4=>4(R, A[1]) }
			NEW { @L_ZERO:32 32 4=>0(I, A[0], -) } @ 32
			EVAL { @L_MUL:32 4=>4(L[0], @OFFSET:32 4=>4(A[1], -)) }
			EVAL { @L_ADD:32 32=>0(R, L[0]) }
			EVAL { @L_ZERO:32 32 8=>0(L[0], A[0], -) }
			EVAL { @L_MUL:32 4=>4(L[0], @OFFSET:32 8=>4(A[1], -)) }
			EVAL { @L_ADD:32 32=>0(R, L[0]) }
			EVAL { @L_ZERO:32 32 12=>0(L[0], A[0], -) }
			EVAL { @L_MUL:32 4=>4(L[0], @OFFSET:32 12=>4(A[1], -)) }
			EVAL { @L_ADD:32 32=>0(R, L[0]) }
			EVAL { @L_ZERO:32 32 16=>0(L[0], A[0], -) }
			EVAL { @L_MUL:32 4=>4(L[0], @OFFSET:32 16=>4(A[1], -)) }
			EVAL { @L_ADD:32 32=>0(R, L[0]) }
			EVAL { @L_ZERO:32 32 20=>0(L[0], A[0], -) }
			EVAL { @L_MUL:32 4=>4(L[0], @OFFSET:32 20=>4(A[1], -)) }
			EVAL { @L_ADD:32 32=>0(R, L[0]) }
			EVAL { @L_ZERO:32 32 24=>0(L[0], A[0], -) }
			EVAL { @L_MUL:32 4=>4(L[0], @OFFSET:32 24=>4(A[1], -)) }
			EVAL { @L_ADD:32 32=>0(R, L[0]) }
			EVAL { @L_ZERO:32 32 28=>0(L[0], A[0], -) }
			EVAL { @L_MUL:32 4=>4(L[0], @OFFSET:32 28=>4(A[1], -)) }
			RET { @L_ADD:32 32=>0(R, L[0]) }
			LEAVE
		}
	}
	classis functio nint256 operator / (nint256 a, nint256 b) {
		nint256 div = a;
		div._div_mod(b);
		responde div;
	}
	classis functio nint256 operator % (nint256 a, nint256 b) {
		nint256 div = a;
		responde div._div_mod(b);
	}
	[[xa]] classis functio nint256 operator | (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 32 : OBJECT
		CODE {
			EVAL { @BLT:8 8=>8(R, @OR:8 8=>8(A[0], A[1])) }
			EVAL { @BLT:8 8=>8(@OFFSET:32 8=>8(R, -), @OR:8 8=>8(@OFFSET:32 8=>8(A[0], -), @OFFSET:32 8=>8(A[1], -))) }
			EVAL { @BLT:8 8=>8(@OFFSET:32 16=>8(R, -), @OR:8 8=>8(@OFFSET:32 16=>8(A[0], -), @OFFSET:32 16=>8(A[1], -))) }
			RET { @BLT:8 8=>8(@OFFSET:32 24=>8(R, -), @OR:8 8=>8(@OFFSET:32 24=>8(A[0], -), @OFFSET:32 24=>8(A[1], -))) }
		}
	}
	[[xa]] classis functio nint256 operator & (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 32 : OBJECT
		CODE {
			EVAL { @BLT:8 8=>8(R, @AND:8 8=>8(A[0], A[1])) }
			EVAL { @BLT:8 8=>8(@OFFSET:32 8=>8(R, -), @AND:8 8=>8(@OFFSET:32 8=>8(A[0], -), @OFFSET:32 8=>8(A[1], -))) }
			EVAL { @BLT:8 8=>8(@OFFSET:32 16=>8(R, -), @AND:8 8=>8(@OFFSET:32 16=>8(A[0], -), @OFFSET:32 16=>8(A[1], -))) }
			RET { @BLT:8 8=>8(@OFFSET:32 24=>8(R, -), @AND:8 8=>8(@OFFSET:32 24=>8(A[0], -), @OFFSET:32 24=>8(A[1], -))) }
		}
	}
	[[xa]] classis functio nint256 operator # (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 32 : OBJECT
		CODE {
			EVAL { @BLT:8 8=>8(R, @XOR:8 8=>8(A[0], A[1])) }
			EVAL { @BLT:8 8=>8(@OFFSET:32 8=>8(R, -), @XOR:8 8=>8(@OFFSET:32 8=>8(A[0], -), @OFFSET:32 8=>8(A[1], -))) }
			EVAL { @BLT:8 8=>8(@OFFSET:32 16=>8(R, -), @XOR:8 8=>8(@OFFSET:32 16=>8(A[0], -), @OFFSET:32 16=>8(A[1], -))) }
			RET { @BLT:8 8=>8(@OFFSET:32 24=>8(R, -), @XOR:8 8=>8(@OFFSET:32 24=>8(A[0], -), @OFFSET:32 24=>8(A[1], -))) }
		}
	}
	classis functio nint256 operator << (nint256 a, nint256 b) { var r = a; responde r <<= b; }
	classis functio nint256 operator >> (nint256 a, nint256 b) { var r = a; responde r >>= b; }
	[[xa]] classis functio logicum operator == (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 1
		CODE { RET { @BLT:1 1=>1(R, @L_EQ:32 32=>1(A[0], A[1])) } }
	}
	[[xa]] classis functio logicum operator != (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 1
		CODE { RET { @BLT:1 1=>1(R, @L_NEQ:32 32=>1(A[0], A[1])) } }
	}
	[[xa]] classis functio logicum operator < (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 1
		CODE { RET { @BLT:1 1=>1(R, @L_L:32 32=>1(A[0], A[1])) } }
	}
	[[xa]] classis functio logicum operator > (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 1
		CODE { RET { @BLT:1 1=>1(R, @L_G:32 32=>1(A[0], A[1])) } }
	}
	[[xa]] classis functio logicum operator <= (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 1
		CODE { RET { @BLT:1 1=>1(R, @L_LE:32 32=>1(A[0], A[1])) } }
	}
	[[xa]] classis functio logicum operator >= (nint256 a, nint256 b) {
		INTERFACE 32 : OBJECT 32 : OBJECT => 1
		CODE { RET { @BLT:1 1=>1(R, @L_GE:32 32=>1(A[0], A[1])) } }
	}
	[[xa]] functio nint32 _adde(nint256 b) {
		INTERFACE W 1 : THIS 32 : OBJECT => 4 : UINT
		CODE { RET { @BLT:4 4=>4(R, @L_ADD:32 32=>4(@PTR_FOLLOW:W 1=>32(A[0]), A[1])) } }
	}
	[[xa]] functio nint32 _mul(nint32 b) {
		INTERFACE W 1 : THIS 4 : UINT => 4 : UINT
		CODE { RET { @BLT:4 4=>4(R, @L_MUL:32 4=>4(@PTR_FOLLOW:W 1=>32(A[0]), A[1])) } }
	}
	[[xa]] functio nint32 _div_mod(nint32 b) {
		INTERFACE W 1 : THIS 4 : UINT => 4 : UINT
		CODE { RET { @BLT:4 4=>4(R, @L_DIV:32 4=>4(@PTR_FOLLOW:W 1=>32(A[0]), A[1])) } }
	}
	[[xa]] functio nint256 _div_mod(nint256 b) {
		INTERFACE W 1 : THIS 32 : OBJECT => 32 : OBJECT
		DATA { QWORD 0 QWORD 0 QWORD 0 QWORD 0 DWORD 255 DWORD 1 }
		CODE {
			ENTER
			; R <- A[0], L[0] <- A[1]
			EVAL { @L_MOV:32 32=>0(R, @PTR_FOLLOW:W 1=>32(A[0])) }
			NEW { @L_MOV:32 32=>0(I, A[1]) } @ 32
			NEW { @L_ZERO:4=>0(I) } @ 4
			; CHECK DIVISION BY ZERO
			JUMPIF { @L_NEQ:32 32=>1(L[0], D[0]) } @ 1
			TRAP
			; L[0] <- L[0] << N: BIT(L[0], 255) == 1; L[1] <- N
			JUMPIF { @L_BIT:32 4=>1(L[0], D[32]) } @ 3
			EVAL { @L_SHL:32 1=>0(L[0], -) }
			EVAL { @BLT:4 4=>4(L[1], @ADD:4 4=>4(L[1], D[36])) }
			JUMP @ -4
			; CLEAR A[0]
			EVAL { @L_ZERO:32=>0(@PTR_FOLLOW:W 1=>32(A[0])) }
			; LOOP WHILE R >= A[1]
			JUMPIF { @L_L:32 32=>1(R, A[1]) } @ 6
			; IF L[0] <= R THE SET THE Nth BIT IN A[0], R <- R - L[0]
			JUMPIF { @L_L:32 32=>1(R, L[0]) } @ 2
			EVAL { @L_SUB:32 32=>0(R, L[0]) }
			EVAL { @L_SET:32 4 4=>0(@PTR_FOLLOW:W 1=>32(A[0]), L[1], D[36]) }
			; L[0] <- L[0] >> 1; N--
			EVAL { @L_SHR:32 1=>0(L[0], -) }
			EVAL { @BLT:4 4=>4(L[1], @SUB:4 4=>4(L[1], D[36])) }
			; LOOP BACK
			JUMP @ -7
			RET
			LEAVE
		}
	}
}

dura int128 {
	[[xa]] [[convertor] "extendens"] structor (logicum org)
	{
		INTERFACE W 1 : THIS 1 : UINT => 0
		CODE { RET { @L_ZERO:16 1=>0(@PTR_FOLLOW:W 1=>16(A[0]), A[1]) } }
	}
	[[xa]] [[convertor] "extendens"] structor (int8 org)
	{
		EXTERNAL "S:int128.>>=:F(RCint128)(Cint128)" DATA DWORD 120
		INTERFACE W 1 : THIS 1 : SINT => 0
		CODE {
			EVAL { @L_ZERO:16 1 15=>0(@PTR_FOLLOW:W 1=>16(A[0]), A[1], -) }
			ENTER
			NEW { @L_ZERO:16 4=>0(I, D[0]) } @ 16
			RET { E[0]:W 1:THIS 16:OBJECT=>W 1(A[0], L[0]) }
